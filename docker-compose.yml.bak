services:
  postgres-catalogo:
    image: postgres:18-alpine
    container_name: nexuscommerce-postgres-catalogo
    restart: unless-stopped
    environment:
      POSTGRES_DB: nexus_catalogo
      POSTGRES_USER: nexus
      POSTGRES_PASSWORD: nexus_dev_password
    ports:
      - "55432:5432"
    volumes:
      - nexuscommerce_catalogo_data:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U nexus -d nexus_catalogo"]
      interval: 5s
      timeout: 5s
      retries: 10

  catalog-api:
    build:
      context: .
      dockerfile: src/Services/Catalog/Catalog.Api/Dockerfile
    container_name: nexuscommerce-catalog-api
    restart: unless-stopped
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_URLS: http://+:8080
      ConnectionStrings__Catalogo: Host=postgres-catalogo;Port=5432;Database=nexus_catalogo;Username=nexus;Password=nexus_dev_password
    ports:
      - "5101:8080"
    depends_on:
      postgres-catalogo:
        condition: service_healthy
    healthcheck:
      test:
        [
          "CMD-SHELL",
          "curl --fail --silent http://localhost:8080/health/ready > /dev/null || exit 1"
        ]
      interval: 10s
      timeout: 5s
      retries: 10

  gateway:
    build:
      context: .
      dockerfile: src/Gateway/NexusCommerce.Gateway/Dockerfile
    container_name: nexuscommerce-gateway
    restart: unless-stopped
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_URLS: http://+:8080
      ReverseProxy__Clusters__cluster-catalogo__Destinations__catalogo-api__Address: http://catalog-api:8080/
    ports:
      - "5000:8080"
    depends_on:
      catalog-api:
        condition: service_healthy
    healthcheck:
      test:
        [
          "CMD-SHELL",
          "curl --fail --silent http://localhost:8080/health/ready > /dev/null || exit 1"
        ]
      interval: 10s
      timeout: 5s
      retries: 10

volumes:
  nexuscommerce_catalogo_data:
